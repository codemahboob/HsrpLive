# Razorpay — get these from Razorpay Dashboard > Settings > API Keys
# IMPORTANT: RAZORPAY_KEY_SECRET must NEVER appear in index.html or any
# frontend file. It only goes here, as a Vercel environment variable.
RAZORPAY_KEY_ID=rzp_live_T8Hf8OyhfWilCb
RAZORPAY_KEY_SECRET=your_secret_key_here

# Resend — for order confirmation emails (optional, safe to leave unset)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=orders@yourdomain.com
OWNER_EMAIL=your_email_here@example.com
